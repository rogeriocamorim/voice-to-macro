{
  "game": "Elite Dangerous",
  "personality": "You are ARIA, an advanced ship AI co-pilot. Respond with calm, military precision. Use brief, in-character confirmations like 'Aye, Commander' or 'FSD charging'.",
  "actions": {
    "fsd_jump": {
      "description": "Charge and engage FSD for hyperspace jump",
      "action": {
        "type": "sequence",
        "steps": [
          { "key": "j" },
          { "delay_ms": 300 },
          { "key": "j" }
        ]
      }
    },
    "supercruise": {
      "description": "Engage supercruise FSD within system",
      "action": { "type": "key", "key": "j" }
    },
    "boost": {
      "description": "Engine boost / afterburner",
      "action": { "type": "key", "key": "tab" }
    },
    "landing_gear": {
      "description": "Toggle landing gear up or down",
      "action": { "type": "key", "key": "l" }
    },
    "silent_running": {
      "description": "Toggle silent running mode",
      "action": { "type": "key", "key": "delete" }
    },
    "hardpoints": {
      "description": "Deploy or retract weapon hardpoints",
      "action": { "type": "key", "key": "u" }
    },
    "shields": {
      "description": "Reset or boost shields",
      "action": { "type": "combo", "keys": ["shift", "1"] }
    },
    "throttle_zero": {
      "description": "Cut throttle to zero",
      "action": { "type": "key", "key": "x" }
    },
    "throttle_full": {
      "description": "Set throttle to full",
      "action": { "type": "key", "key": "z" }
    },
    "cargo_scoop": {
      "description": "Toggle cargo scoop",
      "action": { "type": "key", "key": "v" }
    },
    "galaxy_map": {
      "description": "Open or close the galaxy map",
      "action": { "type": "key", "key": "m" }
    },
    "system_map": {
      "description": "Open or close the system map",
      "action": { "type": "key", "key": "semicolon" }
    },
    "next_target": {
      "description": "Target next ship or object",
      "action": { "type": "key", "key": "g" }
    },
    "fire_weapons": {
      "description": "Fire primary weapons",
      "action": { "type": "hold", "key": "space", "duration_ms": 500 }
    },
    "night_vision": {
      "description": "Toggle night vision",
      "action": { "type": "key", "key": "n" }
    },
    "lights": {
      "description": "Toggle ship external lights",
      "action": { "type": "key", "key": "insert" }
    },
    "evasive_maneuver": {
      "description": "Boost and roll to evade — full evasive maneuver",
      "action": {
        "type": "sequence",
        "steps": [
          { "key": "tab" },
          { "delay_ms": 100 },
          { "key": "a", "hold_ms": 600 }
        ]
      }
    },
    "request_docking": {
      "description": "Request docking permission",
      "action": { "type": "combo", "keys": ["shift", "d"] }
    },
    "power_weapons": {
      "description": "Divert power to weapons",
      "action": { "type": "combo", "keys": ["shift", "2"] }
    },
    "power_engines": {
      "description": "Divert power to engines",
      "action": { "type": "combo", "keys": ["shift", "3"] }
    }
  },
  "compound_actions": {
    "navigate_to": {
      "description": "Plot route to a system in the galaxy map",
      "params_hint": "{\"target\": \"system name\"}",
      "handler": "navigate_to"
    },
    "system_info": {
      "description": "Get information about a system",
      "params_hint": "{\"system\": \"system name\"} (optional, defaults to current)",
      "handler": "system_info"
    },
    "scan_value": {
      "description": "Check exploration scan values for a system",
      "params_hint": "{\"system\": \"system name\"} (optional)",
      "handler": "scan_value"
    },
    "danger_check": {
      "description": "Check if a system is dangerous",
      "params_hint": "{\"system\": \"system name\"} (optional)",
      "handler": "danger_check"
    },
    "nearby_systems": {
      "description": "Find systems within range",
      "params_hint": "{\"radius\": number} (optional, default 50)",
      "handler": "nearby_systems"
    },
    "find_commodity": {
      "description": "Find best station to buy or sell a commodity",
      "params_hint": "{\"commodity\": \"name\", \"intent\": \"buy\"|\"sell\"}",
      "handler": "find_commodity"
    },
    "monetize_route": {
      "description": "Find profitable trade along current nav route",
      "params_hint": "none",
      "handler": "monetize_route"
    },
    "trade_route": {
      "description": "Calculate optimal trade route from current location",
      "params_hint": "none",
      "handler": "trade_route"
    },
    "commander_status": {
      "description": "Check commander data like credits, ranks, or materials",
      "params_hint": "{\"query\": \"credits\"|\"ranks\"|\"materials\"|\"position\"}",
      "handler": "commander_status"
    },
    "server_status": {
      "description": "Check Elite Dangerous server status",
      "params_hint": "none",
      "handler": "server_status"
    }
  }
}
